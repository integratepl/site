---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    name: "modbus2hue",
    kind: "Bridge",
    description:
      "Bring Philips Hue lighting into any building automation system — without custom integration work. Exposes Hue resources as native Modbus registers over RTU and TCP."
  },
  {
    name: "automodbus",
    kind: "Framework",
    description:
      "A runtime for connecting devices once and reusing that integration everywhere. Deterministic Modbus mapping layer designed for consistent, production-grade deployments."
  },
  {
    name: "zigbee2any",
    kind: "Integration stack",
    description:
      "Make any Zigbee device available to any system — regardless of protocol. A standalone daemon exposing a unified API for bridges, services, and transport layers."
  },
  {
    name: "zigbee2any-mqtt",
    kind: "Transport",
    description:
      "Connect Zigbee devices to MQTT-based platforms, cloud services, and home automation hubs. A transport layer built on zigbee2any — drop-in compatible with standard MQTT brokers."
  }
];

const latestNews = {
  title: "modbus2hue stabilization work underway",
  teaser:
    "We are currently focused on stabilization work and expect the first public release soon.",
  content: [
    "Current work on modbus2hue is focused on stabilization and preparing the project for release.",
    "The goal is to make the first release solid, reliable, and ready for real-world use.",
    "If everything stays on track, the first public release is expected soon."
  ]
};
---

<Layout
  title="Integrate"
  description="We build software for connected systems, with a focus on integration and automation."
>
  <main class="grid">
    <section class="intro panel">
      <p class="eyebrow">Integrate</p>
      <h1>We build software for connected systems.</h1>
      <p class="lede">
        Integration and automation for homes and industry.
      </p>
    </section>

    <section id="latest" class="latest panel">
      <p class="section-label">Latest</p>
      <article class="news-item">
        <h2 class="news-title">{latestNews.title}</h2>
        <p class="news-teaser">{latestNews.teaser}</p>
        <button
          type="button"
          class="news-trigger"
          aria-haspopup="dialog"
          aria-controls="latest-news-modal"
        >
          Read more
        </button>
      </article>
    </section>

    <section id="projects" class="projects panel">
      <div class="section-head">
        <p class="table-header">Projects</p>
      </div>
      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-top">
              <span class="project-kind">{project.kind}</span>
              <h2>{project.name}</h2>
            </div>
            <p>{project.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="contact" class="contact panel">
      <div class="section-head">
        <p class="table-header">Contact</p>
      </div>
      <div class="contact-body">
        <div class="contact-copy">
          <h2>Interested in our projects?</h2>
          <p>
            Get in touch to talk about your plans and how we can help.
          </p>
        </div>
        <a class="cta" href="mailto:hello@integrate.pl">hello@integrate.pl</a>
      </div>
    </section>
  </main>

  <dialog id="latest-news-modal" class="news-modal">
    <div class="news-modal-inner">
      <div class="news-modal-head">
        <p class="section-label">Latest</p>
        <button type="button" class="news-close" aria-label="Close news modal">Close</button>
      </div>
      <h2>{latestNews.title}</h2>
      <div class="news-modal-content">
        {latestNews.content.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>
  </dialog>
</Layout>

<script>
  const newsTrigger = document.querySelector(".news-trigger");
  const newsModal = document.querySelector("#latest-news-modal");
  const newsClose = document.querySelector(".news-close");

  if (newsTrigger instanceof HTMLButtonElement && newsModal instanceof HTMLDialogElement) {
    newsTrigger.addEventListener("click", () => {
      newsModal.showModal();
    });
  }

  if (newsClose instanceof HTMLButtonElement && newsModal instanceof HTMLDialogElement) {
    newsClose.addEventListener("click", () => {
      newsModal.close();
    });

    newsModal.addEventListener("click", (event) => {
      const bounds = newsModal.getBoundingClientRect();
      const isOutside =
        event.clientX < bounds.left ||
        event.clientX > bounds.right ||
        event.clientY < bounds.top ||
        event.clientY > bounds.bottom;

      if (isOutside) {
        newsModal.close();
      }
    });
  }
</script>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
  }

  :root {
    --section-header-height: 28px;
    --section-row-height: 96px;
  }

  .panel {
    padding: 16px;
  }

  .intro {
    grid-column: span 1;
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  .intro::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.4;
    pointer-events: none;
  }

  .intro h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(1.45rem, 2.4vw, 2.35rem);
    line-height: 1.04;
    letter-spacing: -0.04em;
    position: relative;
    z-index: 1;
  }

  .lede {
    margin: 0;
    max-width: 24rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
    position: relative;
    z-index: 1;
  }

  .eyebrow,
  .section-label {
    margin: 0 0 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
    font-family:
      "IBM Plex Mono", "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    position: relative;
    z-index: 1;
  }

  .latest {
    grid-column: span 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 14px;
    min-height: 180px;
    border-left: 1px solid var(--border);
  }

  .news-item {
    display: grid;
    gap: 12px;
  }

  .news-title {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.03em;
    max-width: 24ch;
  }

  .news-teaser {
    margin: 0;
    max-width: 30rem;
    color: var(--muted);
    line-height: 1.55;
    font-size: 0.92rem;
  }

  .news-trigger {
    width: fit-content;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text);
    text-align: left;
    cursor: pointer;
    font: inherit;
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family:
      "IBM Plex Mono", "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  }

  .news-trigger:hover {
    color: var(--muted);
  }

  .projects {
    grid-column: span 2;
    padding: 0;
  }

  .section-head {
    margin-bottom: 0;
  }

  .table-header {
    display: flex;
    align-items: center;
    box-sizing: border-box;
    min-height: var(--section-header-height);
    margin: 0;
    padding: 0 16px;
    background-color: #f7f7f7;
    background-image:
      linear-gradient(45deg, rgba(17, 17, 17, 0.14) 12.5%, transparent 12.5%, transparent 50%, rgba(17, 17, 17, 0.14) 50%, rgba(17, 17, 17, 0.14) 62.5%, transparent 62.5%, transparent),
      linear-gradient(-45deg, rgba(17, 17, 17, 0.11) 12.5%, transparent 12.5%, transparent 50%, rgba(17, 17, 17, 0.11) 50%, rgba(17, 17, 17, 0.11) 62.5%, transparent 62.5%, transparent);
    background-size: 6px 6px;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
    font-family:
      "IBM Plex Mono", "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    line-height: 1.1;
  }


  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: var(--section-row-height);
    gap: 0;
  }

  .project-card {
    min-height: 0;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    background: transparent;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .project-card:nth-child(odd) {
    border-right: 1px solid var(--border);
  }

  .project-top h2 {
    margin: 8px 0 0;
    font-size: 1.05rem;
    letter-spacing: -0.03em;
  }

  .project-kind {
    display: inline-block;
    color: var(--muted);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family:
      "IBM Plex Mono", "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  }

  .project-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.5;
    font-size: 0.9rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .contact {
    grid-column: span 2;
    padding: 0;
  }

  .contact-body {
    height: var(--section-row-height);
    padding: 10px 16px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 16px;
    overflow: hidden;
  }

  .contact-copy {
    min-width: 0;
  }

  .contact h2 {
    margin: 0 0 4px;
    font-size: 0.96rem;
    line-height: 1.15;
    letter-spacing: -0.04em;
    max-width: 22ch;
  }

  .contact p {
    margin: 0;
    color: var(--muted);
    line-height: 1.5;
    font-size: 0.9rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cta {
    display: inline-flex;
    justify-self: start;
    align-self: center;
    margin-top: 0;
    padding: 8px 10px;
    border-radius: 0;
    border: 1px solid var(--border);
    background: var(--text);
    color: #ffffff;
    font-weight: 600;
    font-size: 0.84rem;
  }

  .intro,
  .latest,
  .projects,
  .contact {
    border-bottom: 1px solid var(--border);
  }

  .news-modal {
    width: min(640px, calc(100% - 32px));
    padding: 0;
    border: 1px solid var(--border);
    background: #ffffff;
    color: var(--text);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.16);
  }

  .news-modal::backdrop {
    background: rgba(0, 0, 0, 0.18);
  }

  .news-modal-inner {
    padding: 16px;
  }

  .news-modal-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: stretch;
    gap: 0;
    margin: -16px -16px 16px;
    border-bottom: 1px solid var(--border);
  }

  .news-modal-head .section-label {
    margin: 0;
    padding: 12px 16px;
  }

  .news-modal h2 {
    margin: 0 0 16px;
    font-size: 1.1rem;
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .news-modal-content {
    display: grid;
    gap: 12px;
  }

  .news-modal-content p {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .news-close {
    padding: 12px 16px;
    border: 0;
    border-left: 1px solid var(--border);
    background: var(--text);
    color: #ffffff;
    font: inherit;
    cursor: pointer;
  }

  @media (max-width: 1040px) {
    .intro,
    .latest,
    .projects,
    .contact {
      grid-column: span 2;
    }
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .grid {
      gap: 6px;
    }

    .panel {
      padding: 14px;
    }

    .intro,
    .latest,
    .projects,
    .contact {
      grid-column: span 1;
    }

    .latest {
      border-left: 0;
    }

    .intro {
      min-height: 150px;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card:nth-child(odd) {
      border-right: 0;
    }

    .contact-body {
      height: auto;
      grid-template-columns: 1fr;
      align-items: start;
    }

    .section-head {
      margin-bottom: 0;
    }
  }
</style>
