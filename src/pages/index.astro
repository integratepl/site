---
import Layout from "../layouts/Layout.astro";
import HomeIntro from "../components/home/HomeIntro.astro";
import HomeLatest from "../components/home/HomeLatest.astro";
import HomeProjects from "../components/home/HomeProjects.astro";
import HomeContact from "../components/home/HomeContact.astro";
import LatestNewsModal from "../components/home/LatestNewsModal.astro";
import ProjectModal from "../components/home/ProjectModal.astro";
import { buildHomeJsonLd } from "../lib/seo-jsonld";
import { contactEmail, contactMap, contactMeta, latestNews, projects } from "../data/home";
import "../styles/home/index.css";

const siteHref = (Astro.site ?? new URL("https://integrate.pl/")).href;
const canonical = new URL(Astro.url.pathname, siteHref).href;

const pageTitle = "Integrate — software for connected systems";
const pageDescription =
  "Integrate.pl builds integration and automation software for homes and industry: Modbus, Zigbee, MQTT, and bridges such as modbus2hue, automodbus, zigbee2any.";

const keywords =
  "Integrate.pl, industrial integration, home automation, Modbus, Zigbee, MQTT, modbus2hue, automodbus, zigbee2any, zigbee2any-mqtt, Milicz, Poland";
const ogImage = new URL("/og.svg", siteHref).href;

const jsonLd = buildHomeJsonLd({
  siteHref,
  canonicalHref: canonical,
  pageTitle,
  pageDescription,
  projects,
  contactMeta,
  contactEmail
});
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  siteHref={siteHref}
  keywords={keywords}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <main class="grid">
    <HomeIntro />
    <HomeLatest news={latestNews} />
    <HomeProjects projects={projects} />
    <HomeContact meta={contactMeta} map={contactMap} />
  </main>

  <LatestNewsModal news={latestNews} />
  <ProjectModal projects={projects} />
</Layout>

<script>
  import "../scripts/home-client.ts";
</script>
