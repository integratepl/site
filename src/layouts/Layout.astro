---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Integrate",
  description = "We build software for connected systems."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light;
        --bg: #ffffff;
        --bg-grid: rgba(0, 0, 0, 0.045);
        --panel: #ffffff;
        --panel-strong: #f6f6f6;
        --border: #111111;
        --border-soft: rgba(17, 17, 17, 0.16);
        --text: #111111;
        --muted: #666666;
        --accent: #2f6bff;
        --shadow: none;
        --radius-lg: 0;
        --radius-md: 0;
        --radius-sm: 0;
        --container: 1180px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background:
          linear-gradient(var(--bg-grid) 1px, transparent 1px),
          linear-gradient(90deg, var(--bg-grid) 1px, transparent 1px),
          linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
        background-size: 28px 28px, 28px 28px, auto;
        background-color: var(--bg);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .shell {
        width: min(calc(100% - 32px), var(--container));
        margin: 0 auto;
        padding: 0;
        border: 2px solid var(--border);
        overflow: hidden;
        margin-top: 32px;
        margin-bottom: 16px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 18px 48px rgba(0, 0, 0, 0.08);
      }

      .panel {
        background: transparent;
      }

      .footer {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-top: 0;
        padding: 14px 16px;
        color: var(--muted);
        font-size: 0.84rem;
        border-top: 1px solid var(--border);
        background: transparent;
      }

      @media (max-width: 820px) {
        .footer {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <slot />

      <footer class="panel footer">
        <span>We build software for connected systems.</span>
        <a href="https://integrate.pl">integrate.pl</a>
      </footer>
    </div>
  </body>
</html>
