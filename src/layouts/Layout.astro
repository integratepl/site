---
import FaqModal from "../components/home/FaqModal.astro";
import { faqItems, faqModalTitle } from "../data/home";
import "../styles/tokens.css";
import "../styles/base.css";
/* FAQ lives in Layout; shared dialog styles (also used on the homepage via home/index.css). */
import "../styles/home/modal.css";

interface Props {
  title?: string;
  description?: string;
  /** Absolute canonical URL (https://…/path) */
  canonical: string;
  /** Site origin with trailing slash optional — used for Open Graph */
  siteHref: string;
  keywords?: string;
  /** Optional absolute image URL for social previews */
  ogImage?: string;
  /** application/ld+json payload (already stringified) */
  jsonLd?: string;
  /** Prevent indexing (e.g. staging) */
  noindex?: boolean;
}

const {
  title = "Integrate",
  description = "We build software for connected systems.",
  canonical,
  siteHref,
  keywords,
  ogImage,
  jsonLd,
  noindex = false
} = Astro.props;

const ogLocale = "en_GB";
const ogType = "website";
const pageTitle = title.includes("Integrate") ? title : `${title} | Integrate`;
const origin = siteHref.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords ? <meta name="keywords" content={keywords} /> : null}
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="author" content="Integrate.pl" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Integrate" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage ? (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:alt" content={pageTitle} />
      </>
    ) : null}

    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage ? <meta name="twitter:image" content={ogImage} /> : null}

    <link rel="me" href="https://github.com/integratepl" />

    {jsonLd ? <script is:inline type="application/ld+json" set:html={jsonLd} /> : null}
  </head>
  <body>
    <div class="shell">
      <slot />

      <footer class="panel footer">
        <button
          type="button"
          class="footer-faq-btn"
          aria-haspopup="dialog"
          aria-controls="faq-modal"
        >
          FAQ
        </button>
        <div class="footer-links">
          <a href={origin}>integrate.pl</a>
          <a
            class="footer-github"
            href="https://github.com/integratepl"
            rel="noopener noreferrer me"
            target="_blank"
            aria-label="Integrate on GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              />
            </svg>
          </a>
        </div>
      </footer>

      <FaqModal title={faqModalTitle} items={faqItems} />
    </div>

    <script>
      import "../scripts/footer-faq.ts";
    </script>
  </body>
</html>
