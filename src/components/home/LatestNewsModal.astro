---
import type { LatestNews } from "../../data/home";

interface Props {
  items: LatestNews[];
}

const { items } = Astro.props;

const payload = items.map((n) => ({
  slug: n.slug,
  title: n.title,
  content: n.content
}));

const newsModalJson = JSON.stringify(payload).replace(/</g, "\\u003c");
---

<dialog id="latest-news-modal" class="news-modal" aria-labelledby="latest-news-modal-title">
  <div class="news-modal-inner">
    <div class="news-modal-head">
      <p class="section-label">Latest</p>
      <button type="button" class="news-close modal-close-btn" aria-label="Close news modal">Close</button>
    </div>
    <h2 id="latest-news-modal-title"></h2>
    <div id="latest-news-modal-content" class="news-modal-content"></div>
  </div>
</dialog>

<script is:inline type="application/json" id="latest-news-modal-data" set:html={newsModalJson} />
