---
import type { Project } from "../../data/home";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const payload = projects.map((p) => ({
  slug: p.slug,
  name: p.name,
  kind: p.kind,
  description: p.description,
  releaseUrl: p.releaseUrl ?? null,
  githubReleases: p.githubReleases ?? null,
  licensePrice: p.licensePrice ?? null
}));

const projectModalJson = JSON.stringify(payload).replace(/</g, "\\u003c");
---

<dialog id="project-modal" class="project-modal" aria-labelledby="project-modal-title">
  <div class="project-modal-inner">
    <div class="project-modal-head">
      <p class="section-label">Project</p>
      <button type="button" class="modal-close-btn" data-project-modal-close aria-label="Close project details">
        Close
      </button>
    </div>
    <p class="project-modal-kind" id="project-modal-kind"></p>
    <h2 id="project-modal-title"></h2>
    <div class="project-modal-content">
      <p id="project-modal-description"></p>

      <section
        id="project-modal-license-section"
        class="project-modal-section"
        aria-labelledby="project-license-heading"
        hidden
      >
        <h3 class="project-modal-subhead" id="project-license-heading">License</h3>
        <p id="project-modal-license"></p>
      </section>

      <section
        id="project-modal-binaries-section"
        class="project-modal-section project-modal-releases-block"
        aria-labelledby="project-modal-releases-heading"
        hidden
      >
        <h3 class="project-modal-subhead" id="project-modal-releases-heading">Releases</h3>
        <div id="project-modal-version-row" class="project-modal-version-row" hidden>
          <select
            id="project-modal-version"
            class="project-modal-version"
            aria-labelledby="project-modal-releases-heading"></select>
        </div>

        <div id="project-modal-release-head-row" class="project-modal-release-head-row" hidden></div>

        <section
          id="project-modal-notes-section"
          class="project-modal-section project-modal-subsection"
          aria-labelledby="project-notes-heading"
          hidden
        >
          <h3 class="project-modal-subhead" id="project-notes-heading">Release notes</h3>
          <pre id="project-modal-release-notes" class="project-modal-release-notes"></pre>
        </section>

        <section
          id="project-modal-docker-section"
          class="project-modal-section project-modal-subsection"
          aria-labelledby="project-docker-heading"
          hidden
        >
          <h3 class="project-modal-subhead" id="project-docker-heading">Docker image</h3>
          <pre class="project-modal-code"><code id="project-modal-docker"></code></pre>
        </section>

        <section
          id="project-modal-binaries-assets-section"
          class="project-modal-section project-modal-subsection"
          aria-labelledby="project-modal-binaries-heading"
        >
          <h3 class="project-modal-subhead" id="project-modal-binaries-heading">Binaries</h3>
          <div id="project-modal-releases-root" class="project-modal-releases-root"></div>
        </section>
      </section>
    </div>
  </div>
</dialog>

<script is:inline type="application/json" id="project-modal-data" set:html={projectModalJson} />
